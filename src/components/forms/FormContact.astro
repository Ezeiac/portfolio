<div class="w-full p-6 rounded-2xl border border-currentColor">
    <form id="form" action="https://api.web3forms.com/submit" method="POST" class="space-y-4">
        <input type="hidden" name="access_key" value="113f04a5-cec8-43dd-a199-d037aa88e073" />
        <input type="hidden" name="redirect" value="/" />
        
        <div class="flex flex-col md:flex-row justify-between gap-4">
            <input
                type="text"
                name="name"
                class="md:w-1/2 border border-[currentColor] focus:border-zinc-700 focus:outline-none rounded-xl py-3 px-4 text-[currentColor] transition-colors"
                placeholder="Nombre"
                required
            />
            <input
                type="email"
                name="email"
                class="md:w-1/2 border border-[currentColor] focus:border-zinc-700 focus:outline-none rounded-xl py-3 px-4 text-[currentColor] transition-colors"
                placeholder="Mail"
                required
            />
        </div>
        
        <textarea
            name="message"
            placeholder="Mensaje"
            class="field-sizing-content w-full min-h-[8em] border border-[currentColor] focus:border-zinc-700 focus:outline-none rounded-xl py-3 px-4 text-[currentColor] placeholder-[currentColor] transition-colors"
            required></textarea>
        
        <button
            id="submit"
            type="submit"
            class="flex overflow-hidden h-12 rounded-xl border border-[currentColor] md:hover:bg-zinc-900 md:hover:text-white w-full cursor-pointer justify-center items-center relative duration-300 font-medium"
        >
            <div id="submitText" class="absolute flex flex-col items-center justify-center duration-300 h-[300%] top-0">
                <p class="h-12 flex items-center justify-center">Enviar mensaje</p>
                <p class="h-12 flex items-center justify-center text-yellow-500">Enviando...</p>
                <p class="h-12 flex items-center justify-center text-green-500">Mensaje enviado</p>
            </div>
            <div id="submitError" class="absolute transition-opacity duration-300 opacity-0 text-red-400 pointer-events-none">
                <p>Error al enviar mensaje</p>
            </div>
        </button>
    </form>
</div>

<script>
    import { getNodes } from "@/scripts/nodes";

    const delay = (ms: number) => new Promise<void>((resolve) => setTimeout(resolve, ms));

    document.addEventListener("DOMContentLoaded", () => {
        const { form, submit, submitText, submitError } = getNodes();

        if (form) {
            form.addEventListener("submit", async (e) => {
                e.preventDefault();
                if (!submit || !submitText || !submitError) return;

                submit.disabled = true;
                submitText.style.transform = "translateY(-33.33%)";

                const formData = new FormData(form);

                try {
                    const response = await fetch("https://api.web3forms.com/submit", {
                        method: "POST",
                        body: formData,
                    });

                    if (response.ok) {
                        form.reset();
                        
                        submitText.style.transform = "translateY(-66.66%)";
                        
                        await delay(4000); 

                        submitText.classList.add("opacity-0");
                        await delay(300);

                        submitText.style.transform = "translateY(0%)";
                        submitText.classList.remove("opacity-0");
                        
                        submit.disabled = false;
                    } else {
                        await handleFormError();
                    }
                } catch (error) {
                    await handleFormError();
                }
            });
        }

        async function handleFormError() {
            if (!submit || !submitText || !submitError) return;

            submitText.classList.add("opacity-0");
            await delay(300);

            submitError.classList.remove("opacity-0");
            await delay(4000);

            submitError.classList.add("opacity-0");
            await delay(300);

            submitText.style.transform = "translateY(0%)";
            submitText.classList.remove("opacity-0");

            submit.disabled = false;
        }
    });
</script>