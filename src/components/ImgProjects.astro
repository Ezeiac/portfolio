<style
    is:global
    set:html={`
    ${allSkillsFlat
        .map(
            (s: Record<string, string>) => `
        .${s.name.replace(/\s+/g, "")} .textIcon::before { 
            content: "";
            mask: url(${s.url}) no-repeat center;
            -webkit-mask: url(${s.url}) no-repeat center;
            background-color: currentColor; 
            display: inline-block;
            width: 1.5rem;
            height: 1.5rem;
            vertical-align: middle;
        }
        `,
        )
        .join("\n")}

        #${data.img.replace(/\s+/g, "")} .bordercol,
        #${data.img.replace(/\s+/g, "")} .bordercard { 
            border-color: ${data.color}80
        }

        #${data.img.replace(/\s+/g, "")} .bordercardmini { 
            border-color: ${data.color}50
        }

        #${data.img.replace(/\s+/g, "")}:hover .bordercol,
        #${data.img.replace(/\s+/g, "")}:hover .bordercard,
        #${data.img.replace(/\s+/g, "")} .tooltip { 
            border-color: ${data.color}
        }

        #${data.img.replace(/\s+/g, "")}:hover .bordercard { 
            box-shadow: 0px 0px 15px ${data.color}, 0px 0px 20px ${data.color}35;
        }
    `}
></style>
