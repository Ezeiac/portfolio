---
import ImgProjects from "@/components/ImgProjects.astro";
import type { imagesType } from "@/types/project";

interface Props {
    project: any;
    typesSameTechs: string[];
    allSkillsFlat: any;
}

const { project, typesSameTechs, allSkillsFlat } = Astro.props;
const isCarouselStyle = typesSameTechs.includes(project.type);
---

<div data-catall={project.category} class="w-full duration-400 isFilter">
    {
        isCarouselStyle ? (
            <div class="relative group/carousel w-full">
                <div class="mb-4 border-b pb-2">
                    <h3>{project.category}</h3>
                    <span class="text-sm text-(--text-secondary) flex self-center max-w-[calc(100%-70px)]">
                        Ecosistema de proyectos compartiendo un mismo stack
                        tecnológico
                    </span>
                </div>
                {project.data.length > 1 && (
                    <div class="flex flex-col lg:flex-row lg:max-w-full justify-self-center">
                        <div class="flex w-full self-center min-w-[48%] max-w-80 w-[70%] lg:min-w-[31%] mx-[1%] contenedor-destacados">
                            {project.data.map((t: imagesType, i: number) => (
                                <div
                                    data-destacado-cat={project.category}
                                    data-destacado-index={i}
                                    class={
                                        i === 0
                                            ? "block duration-800 w-full"
                                            : "hidden duration-800 w-full"
                                    }
                                >
                                    <ImgProjects
                                        data={t}
                                        index={i}
                                        allSkillsFlat={allSkillsFlat}
                                    />
                                </div>
                            ))}
                        </div>

                        <div class="flex overflow-x-hidden flex-wrap px-2 content-between">
                            {project.data.map((t: imagesType, i: number) => (
                                <div
                                    class="cursor-pointer transition w-[50%] h-1/3 max-w-1/3 lg:w-[33%] lg:h-1/2"
                                    data-trigger-index={i}
                                    data-trigger-cat={project.category}
                                >
                                    <ImgProjects
                                        data={t}
                                        index={i}
                                        allSkillsFlat={allSkillsFlat}
                                        type={project.type}
                                    />
                                </div>
                            ))}
                        </div>
                    </div>
                )}
            </div>
        ) : (
            <div>
                <div class="mb-4 border-b pb-2">
                    <h3>{project.category}</h3>
                </div>
                <div class="flex flex-wrap w-full justify-center md:justify-start">
                    {project.data.map((t: imagesType, i: number) => (
                        <div class="md:max-w-[48%] lg:max-w-[31%] max-w-80 mx-[1%] w-full">
                            <ImgProjects
                                data={t}
                                index={i}
                                allSkillsFlat={allSkillsFlat}
                            />
                        </div>
                    ))}
                </div>
            </div>
        )
    }
</div>
