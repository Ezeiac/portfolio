---
import { Icon } from "astro-icon/components";
import { listSkills } from "@/helpers/skills";

export const allSkillsFlat = listSkills.flatMap((c) => c.skills);

const skillsWCat = allSkillsFlat.map((i) => {
    const findCat = listSkills.find((f) =>
        f.skills.some((s) => s.name === i.name),
    );

    return {
        ...i,
        cat: findCat ? findCat.category : "Sin categoria",
    };
});

const favTechs = skillsWCat.filter((f) => f.fav);
const restTechs = skillsWCat.filter((f) => !f.fav);
---

<section id="skills" class="md:pt-16 pt-4 px-2 justify-items-center">
    <h2>Mi Stack</h2>
    <div class="justify-self-center">
        <div
            id="containerIcons"
            class="flex justify-self-center py-8 max-w-[90%]"
        >
            <div class="relative">
                <h3 class="w-full text-center mb-4 md:mb-6">Las preferidas</h3>
                <div
                    class="flex flex-wrap justify-center gap-4 relative w-full"
                >
                    {
                        favTechs
                            .sort(
                                (a, b) =>
                                    (a.order ?? Infinity) -
                                    (b.order ?? Infinity),
                            )
                            .map((f, i) => {
                                return (
                                    <div class="flex justify-center">
                                        <div
                                            data-pos={i}
                                            class="w-full px-1 justify-items-center"
                                        >
                                            <Icon
                                                name={f.repo}
                                                class="h-20 max-h-10 w-full mb-3"
                                            />
                                            <p
                                                class="transition-opacity techName"
                                                style="opacity:0.5"
                                            >
                                                {f.name}
                                            </p>
                                        </div>
                                    </div>
                                );
                            })
                    }
                </div>
            </div>
        </div>
        <div
            id="containerOthers"
            class="flex justify-self-center py-8 max-w-[90%]"
        >
            <div class="relative w-full">
                <h2 class="w-full text-center mb-4 md:mb-6">
                    Otras tecnologias y herramientas
                </h2>

                <div
                    class="flex flex-wrap justify-center gap-4 relative w-full"
                >
                    {
                        restTechs.map((f, i) => {
                            return (
                                <div class="flex justify-center text-center">
                                    <div
                                        data-pos={i}
                                        class="flex flex-col items-center w-full px-1"
                                    >
                                        <Icon
                                            name={f.repo}
                                            class="w-10 h-10 mb-3 object-contain"
                                        />
                                        <p
                                            class="transition-opacity techName"
                                            style="opacity:0.5"
                                        >
                                            {f.name}
                                        </p>
                                    </div>
                                </div>
                            );
                        })
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { mediaQ } from "@/scripts/nodes";
    
    const iconScale = (
        containerId: string,
        maxScale = 1.6,
        rangeDistance = 150,
        isMobile: boolean,
    ) => {
        const container = document.getElementById(containerId);
        const elementIconText =
            container?.querySelectorAll<HTMLElement>(".techName");
        const elementsSvg = container?.querySelectorAll<SVGElement>("svg");

        if (!container || !elementsSvg || !elementIconText) return;

        const listenerIn = isMobile ? "touchmove" : "mousemove";
        const listenerOut = isMobile ? "touchend" : "mouseleave";

        container.addEventListener(
            listenerIn,
            (event: MouseEvent | TouchEvent) => {
                let mouseX = 0;
                let mouseY = 0;

                if (
                    isMobile &&
                    "touches" in event &&
                    event.touches.length > 0
                ) {
                    mouseX = event.touches[0].clientX;
                    mouseY = event.touches[0].clientY;
                } else {
                    const mouseEvent = event as MouseEvent;
                    mouseX = mouseEvent.clientX;
                    mouseY = mouseEvent.clientY;
                }

                elementsSvg.forEach((icon, i) => {
                    const rect = icon.getBoundingClientRect();

                    const iconCenterX = rect.left + rect.width / 2;
                    const iconCenterY = rect.top + rect.height / 2;

                    const distanceX = mouseX - iconCenterX;
                    const distanceY = mouseY - iconCenterY;
                    const distance = Math.sqrt(
                        distanceX * distanceX + distanceY * distanceY,
                    );

                    if (distance < rangeDistance) {
                        const proximity = distance / rangeDistance;
                        const intensity = Math.cos((proximity * Math.PI) / 2);
                        const currentScale = 1 + (maxScale - 1) * intensity;
                        icon.style.scale = `${currentScale}`;
                        if (intensity > 0.5) {
                            elementIconText[i].style.opacity = `${intensity}`;
                        } else {
                            elementIconText[i].style.opacity = "0.5";
                        }
                    } else {
                        icon.style.scale = "1";
                    }
                });
            },
        );

        container.addEventListener(listenerOut, () => {
            elementsSvg.forEach((icon, i) => {
                icon.style.scale = "1";
            });
        });
    };

    document.addEventListener("DOMContentLoaded", () => {

        const applyEffect = (e: MediaQueryListEvent | MediaQueryList) => {
            const n1 = document.getElementById("containerIcons");
            const n2 = document.getElementById("containerOthers");
            if (n1) n1.replaceWith(n1.cloneNode(true));
            if (n2) n2.replaceWith(n2.cloneNode(true));

            if (e.matches) {
                iconScale("containerIcons", 1.6, 100, true);
                iconScale("containerOthers", 1.3, 80, true);
            } else {
                iconScale("containerIcons", 1.6, 100, false);
                iconScale("containerOthers", 1.3, 80, false);
            }
        };

        applyEffect(mediaQ);

        mediaQ.addEventListener("change", applyEffect);
    });
</script>
